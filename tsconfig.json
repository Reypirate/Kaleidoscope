{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@repo/db": ["./packages/db/index.ts"],
      "@repo/shared": ["./packages/shared/index.ts"],
      "@repo/api": ["./apps/api/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
