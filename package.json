{
  "name": "react-hono-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "oxlint .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "oxfmt .",
    "clean": "git clean -xdf .cache .turbo dist node_modules .tanstack",
    "db:push": "pnpm --filter=@repo/db push",
    "db:studio": "pnpm --filter=@repo/db studio"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=9.15.4"
  },
  "packageManager": "pnpm@9.15.4"
}
